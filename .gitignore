# Deployment secrets (contains AWS keys — never commit)
deploy.env

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# Cache and data files
mergir_cache/
*.log

# Large data (tracked as split files instead)
ibtracs_tracks.json

# pipeline/refresh_ibtracs.py work dirs:
#   data/_ibtracs_cache/      — downloaded source netCDF (~600 MB)
#   data/_ibtracs_smoketest/  — --since-flag sandbox output for diff/inspect
# Both ephemeral; never commit. Underscore prefix marks them as private to
# the pipeline so future data/* additions (like data/indices.json) stay
# trackable without an explicit allow-list.
data/_ibtracs_*/

# Claude Code working state
.claude/
