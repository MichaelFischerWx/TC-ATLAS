Dockerfile
.dockerignore
deploy.sh

# ── Python artifacts ──
__pycache__
*.pyc
*.pyo
.mypy_cache
.ruff_cache
.venv
env

# ── IDE / OS ──
.vscode
.idea
.DS_Store
Thumbs.db

# ── Cached data (MergIR frames — can be huge, NOT needed in container) ──
mergir_cache/

# ── Logs ──
*.log

